# Environment variables for stocks-scoring-agent
# Copy this file to .envrc and fill in your actual values
# Then run: direnv allow .

# Google Gemini API Key (free tier — used by the TradingView sidebar bot chat)
# Get one free at https://aistudio.google.com/apikey
export GEMINI_API_KEY='your-gemini-api-key-here'

# OpenAI API Key
export OPENAI_API_KEY='your-openai-api-key-here'

# Polygon.io API Key (for stock market data)
export POLYGON_API_KEY='your-polygon-api-key-here'

# x.ai API Key (for Reddit/X sentiment research)
export XAI_API_KEY='your-xai-api-key-here'

# SEC EDGAR Identity Email (required for SEC filing downloads)
# This email will be used to identify yourself when making requests to SEC's EDGAR system
export SEC_IDENTITY_EMAIL='your-email@example.com'

# Add other API keys or environment variables as needed
