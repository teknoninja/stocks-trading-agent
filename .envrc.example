# Environment variables for stocks-scoring-agent
# Copy this file to .envrc and fill in your actual values
# Then run: direnv allow .

# Google Gemini API Key (free tier — used by the TradingView sidebar bot chat)
# Get one free at https://aistudio.google.com/apikey
export GEMINI_API_KEY='your-gemini-api-key-here'

# Alpaca PAPER trading keys (free — https://alpaca.markets, Paper dashboard)
# Used by the "Paper trade" sidebar button and the watchlist scanner.
export ALPACA_API_KEY='your-alpaca-paper-key'
export ALPACA_SECRET_KEY='your-alpaca-paper-secret'

# GitHub token + repo for the sidebar "Auto trading" toggle (optional —
# you can also flip the AUTO_TRADING variable on github.com by hand).
# Fine-grained token, single repo, permission: Actions variables read/write.
export GITHUB_TOKEN='your-github-token'
export GITHUB_REPO='yourname/stocks-trading-agent'

# Scanner tuning (defaults shown)
# export TV_BOT_NOTIONAL='1000'   # $ per position (US / Alpaca)
# export TV_BOT_MIN_CONF='0.55'   # min flag confidence to buy
# export TV_BOT_MAX_POS='10'      # max open positions
# export TV_BOT_MAX_DD='0.03'     # daily drawdown circuit breaker (3%)
# export TV_BOT_START_CASH_INR='1000000'  # NSE virtual portfolio starting cash
# export TV_BOT_NOTIONAL_INR='1000'       # ₹ budget per NSE position (whole shares;
#                                         #  falls back to 1 share when price > budget)
# export TV_BOT_MIN_ONE_SHARE='1'         # set 0 to strictly skip stocks above budget

# OpenAI API Key
export OPENAI_API_KEY='your-openai-api-key-here'

# Polygon.io API Key (for stock market data)
export POLYGON_API_KEY='your-polygon-api-key-here'

# x.ai API Key (for Reddit/X sentiment research)
export XAI_API_KEY='your-xai-api-key-here'

# SEC EDGAR Identity Email (required for SEC filing downloads)
# This email will be used to identify yourself when making requests to SEC's EDGAR system
export SEC_IDENTITY_EMAIL='your-email@example.com'

# Add other API keys or environment variables as needed
