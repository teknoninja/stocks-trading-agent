{
  "manifest_version": 3,
  "name": "Stock Flag Bot",
  "version": "1.0.0",
  "description": "BUY/SELL/HOLD flag sidebar for TradingView, powered by your local analysis server (127.0.0.1:8765).",
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://*.tradingview.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
